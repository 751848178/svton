# Application
NODE_ENV=development
PORT=3101
CORS_ORIGIN=http://localhost:3100

# Logging
LOG_LEVEL=debug

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/devpilot"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache
CACHE_ENABLED=true
CACHE_TTL=300

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# OAuth - Gitee
GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=

# Encryption (for resource credentials - must be 32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key!

# Local Docker resources (see docker-compose.devpilot-staging.yml)
# Optional. When set, the local staging stack wires these into the relevant
# services (SMTP for alert notification delivery, MinIO for S3-compatible
# object storage standing in for qiniu/tencent-cos). Leave commented out for
# production; the production values come from the real provider.
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# MAIL_FROM=devpilot@staging.local
# MINIO_ENDPOINT=http://127.0.0.1:9100
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio12345
# MINIO_BUCKET=devpilot-test

# ---------- Bootstrap admin (optional) ----------
# When both are set, the API provisions a system-level admin (role=admin) on startup.
# Leave unset in environments where no bootstrap admin is desired (silent no-op).
# Choose a strong password; the API does not enforce RegisterDto's password policy on this value.
DEVPILOT_BOOTSTRAP_ADMIN_EMAIL=
DEVPILOT_BOOTSTRAP_ADMIN_PASSWORD=
#
# Operational recovery: if the env vars are not set on first deploy, the system
# has NO admin and no way to become one through the API. To recover, EITHER:
#   1. set both env vars above and restart the API (bootstrap will create the
#      admin on next boot), OR
#   2. run a one-off SQL against the DB:
#        UPDATE User SET role='admin' WHERE email='<your-email>';
