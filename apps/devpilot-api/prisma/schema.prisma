model LogCollectionRun {
  id                   String   @id @default(cuid())
  teamId               String
  streamId             String
  actorId              String?
  projectId            String?
  environmentId        String?
  applicationId        String?
  applicationServiceId String?
  serverId             String?
  siteId               String?
  managedResourceId    String?
  deploymentRunId      String?
  backupPlanId         String?
  backupRunId          String?
  alertEventId         String?
  serverExecutionJobId String?
  sourceType           String
  sourceKey            String?
  executorKey          String   @default("server-executor")
  adapterKey           String   @default("log-collection-plan")
  dryRun               Boolean  @default(true)
  tail                 Int      @default(200)
  status               String   @default("running") // queued | running | completed | failed | blocked | cancelled
  params               Json?
  commandPlan          Json?
  logs                 Json?
  result               Json?
  error                String?  @db.Text
  ingestionStatus      String?  // pending | completed | skipped | failed
  ingestedEntryCount   Int      @default(0)
  ingestionError       String?  @db.Text
  ingestedAt           DateTime?
  startedAt            DateTime @default(now())
  finishedAt           DateTime?
  createdAt            DateTime @default(now())

  team                 Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  stream               LogStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  actor                User?    @relation("LogCollectionRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  project              Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment          ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  application          Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  applicationService   ApplicationService? @relation(fields: [applicationServiceId], references: [id], onDelete: SetNull)
  server               Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  site                 Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managedResource      ManagedResource? @relation(fields: [managedResourceId], references: [id], onDelete: SetNull)
  deploymentRun        DeploymentRun? @relation(fields: [deploymentRunId], references: [id], onDelete: SetNull)
  backupPlan           BackupPlan? @relation(fields: [backupPlanId], references: [id], onDelete: SetNull)
  backupRun            BackupRun? @relation(fields: [backupRunId], references: [id], onDelete: SetNull)
  alertEvent           AlertEvent? @relation(fields: [alertEventId], references: [id], onDelete: SetNull)
  serverExecutionJob   ServerExecutionJob? @relation(fields: [serverExecutionJobId], references: [id], onDelete: SetNull)
  auditEvents          AuditEvent[]

  @@index([teamId])
  @@index([streamId])
  @@index([actorId])
  @@index([projectId])
  @@index([environmentId])
  @@index([applicationId])
  @@index([applicationServiceId])
  @@index([serverId])
  @@index([siteId])
  @@index([managedResourceId])
  @@index([deploymentRunId])
  @@index([backupPlanId])
  @@index([backupRunId])
  @@index([alertEventId])
  @@index([serverExecutionJobId])
  @@index([sourceType])
  @@index([sourceKey])
  @@index([executorKey])
  @@index([adapterKey])
  @@index([dryRun])
  @@index([status])
  @@index([ingestionStatus])
  @@index([startedAt])
}

// 日志保留清理运行记录
model LogRetentionRun {
  id                String   @id @default(cuid())
  teamId            String
  streamId          String?
  actorId           String?
  projectId         String?
  environmentId     String?
  dryRun            Boolean  @default(true)
  retentionDays     Int
  cutoffAt          DateTime
  matchedEntryCount Int      @default(0)
  deletedEntryCount Int      @default(0)
  status            String   @default("running") // running | completed | failed
  error             String?  @db.Text
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  createdAt         DateTime @default(now())

  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  stream            LogStream? @relation(fields: [streamId], references: [id], onDelete: SetNull)
  actor             User?    @relation("LogRetentionRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  auditEvents       AuditEvent[]

  @@index([teamId])
  @@index([streamId])
  @@index([actorId])
  @@index([projectId])
  @@index([environmentId])
  @@index([dryRun])
  @@index([status])
  @@index([cutoffAt])
  @@index([startedAt])
}

// 操作审批
model OperationApproval {
  id                   String   @id @default(cuid())
  teamId               String
  requesterId          String?
  reviewerId           String?
  projectId            String?
  environmentId        String?
  applicationId        String?
  applicationServiceId String?
  serverId             String?
  siteId               String?
  managedResourceId    String?
  category             String   // resource_action | service_operation | deployment
  action               String
  targetType           String
  targetId             String?
  risk                 String   @default("medium") // low | medium | high
  status               String   @default("pending") // pending | approved | rejected | cancelled
  summary              String?  @db.Text
  reason               String?  @db.Text
  reviewComment        String?  @db.Text
  metadata             Json?
  requestedAt          DateTime @default(now())
  reviewedAt           DateTime?
  consumedAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  team                 Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requester            User?    @relation("OperationApprovalRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  reviewer             User?    @relation("OperationApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  project              Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment          ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  application          Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  applicationService   ApplicationService? @relation(fields: [applicationServiceId], references: [id], onDelete: SetNull)
  server               Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  site                 Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managedResource      ManagedResource? @relation(fields: [managedResourceId], references: [id], onDelete: SetNull)
  siteSyncRuns         SiteSyncRun[]
  resourceActionRuns   ResourceActionRun[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  deploymentRuns       DeploymentRun[]
  auditEvents          AuditEvent[]

  @@index([teamId])
  @@index([requesterId])
  @@index([reviewerId])
  @@index([projectId])
  @@index([environmentId])
  @@index([applicationId])
  @@index([applicationServiceId])
  @@index([serverId])
  @@index([siteId])
  @@index([managedResourceId])
  @@index([category])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([risk])
  @@index([status])
  @@index([requestedAt])
  @@index([reviewedAt])
  @@index([consumedAt])
}

// 统一审计事件
model AuditEvent {
  id                                String   @id @default(cuid())
  teamId                            String
  actorId                           String?
  projectId                         String?
  environmentId                     String?
  applicationId                     String?
  applicationServiceId              String?
  serverId                          String?
  siteId                            String?
  managedResourceId                 String?
  deploymentRunId                   String?
  resourceActionRunId               String?
  resourceConnectionRunId           String?
  resourceQueryRunId                String?
  applicationServiceOperationRunId  String?
  siteSyncRunId                     String?
  operationApprovalId               String?
  backupRunId                       String?
  alertEventId                      String?
  logStreamId                       String?
  logEntryId                        String?
  logCollectionRunId                String?
  logRetentionRunId                 String?
  category                          String
  action                            String
  targetType                        String
  targetId                          String?
  risk                              String   @default("low") // low | medium | high
  status                            String   @default("completed") // running | completed | failed | blocked
  summary                           String?  @db.Text
  metadata                          Json?
  occurredAt                        DateTime @default(now())
  createdAt                         DateTime @default(now())

  team                              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor                             User?    @relation("AuditEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  project                           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment                       ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  application                       Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  applicationService                ApplicationService? @relation(fields: [applicationServiceId], references: [id], onDelete: SetNull)
  server                            Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  site                              Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managedResource                   ManagedResource? @relation(fields: [managedResourceId], references: [id], onDelete: SetNull)
  deploymentRun                     DeploymentRun? @relation(fields: [deploymentRunId], references: [id], onDelete: SetNull)
  resourceActionRun                 ResourceActionRun? @relation(fields: [resourceActionRunId], references: [id], onDelete: SetNull)
  resourceConnectionRun             ResourceConnectionRun? @relation(fields: [resourceConnectionRunId], references: [id], onDelete: SetNull)
  resourceQueryRun                  ResourceQueryRun? @relation(fields: [resourceQueryRunId], references: [id], onDelete: SetNull)
  applicationServiceOperationRun    ApplicationServiceOperationRun? @relation(fields: [applicationServiceOperationRunId], references: [id], onDelete: SetNull)
  siteSyncRun                       SiteSyncRun? @relation(fields: [siteSyncRunId], references: [id], onDelete: SetNull)
  operationApproval                 OperationApproval? @relation(fields: [operationApprovalId], references: [id], onDelete: SetNull)
  backupRun                         BackupRun? @relation(fields: [backupRunId], references: [id], onDelete: SetNull)
  alertEvent                        AlertEvent? @relation(fields: [alertEventId], references: [id], onDelete: SetNull)
  logStream                         LogStream? @relation(fields: [logStreamId], references: [id], onDelete: SetNull)
  logEntry                          LogEntry? @relation(fields: [logEntryId], references: [id], onDelete: SetNull)
  logCollectionRun                  LogCollectionRun? @relation(fields: [logCollectionRunId], references: [id], onDelete: SetNull)
  logRetentionRun                   LogRetentionRun? @relation(fields: [logRetentionRunId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([actorId])
  @@index([projectId])
  @@index([environmentId])
  @@index([applicationId])
  @@index([applicationServiceId])
  @@index([serverId])
  @@index([siteId])
  @@index([managedResourceId])
  @@index([deploymentRunId])
  @@index([resourceActionRunId])
  @@index([resourceConnectionRunId])
  @@index([resourceQueryRunId])
  @@index([applicationServiceOperationRunId])
  @@index([siteSyncRunId])
  @@index([operationApprovalId])
  @@index([backupRunId])
  @@index([alertEventId])
  @@index([logStreamId])
  @@index([logEntryId])
  @@index([logCollectionRunId])
  @@index([logRetentionRunId])
  @@index([category])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([risk])
  @@index([status])
  @@index([occurredAt])
}
