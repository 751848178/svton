generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与团队 ====================

// 用户模型
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  avatar        String?
  role          String    @default("user")  // user | admin (系统级别)

  // OAuth 关联
  accounts      Account[]

  // 团队关联
  teamMembers   TeamMember[]

  // 用户创建的数据（保留创建者信息）
  createdResources     Resource[]
  createdPresets       Preset[]
  createdProjects      Project[]
  createdApplications   Application[] @relation("ApplicationCreator")
  gitConnections       GitConnection[]
  allocations          ResourceAllocation[]
  createdSecretKeys    SecretKey[]
  createdServers       Server[]
  createdProxyConfigs  ProxyConfig[]
  createdSites         Site[] @relation("SiteCreator")
  siteSyncRuns         SiteSyncRun[] @relation("SiteSyncRunActor")
  createdCDNConfigs    CDNConfig[]
  createdProjectWebhooks ProjectWebhook[] @relation("ProjectWebhookCreator")
  createdManagedResources ManagedResource[] @relation("ManagedResourceCreator")
  resourceSyncRuns     ResourceSyncRun[] @relation("ResourceSyncRunActor")
  resourceActionRuns   ResourceActionRun[] @relation("ResourceActionRunActor")
  resourceConnectionRuns ResourceConnectionRun[] @relation("ResourceConnectionRunActor")
  resourceQueryRuns    ResourceQueryRun[] @relation("ResourceQueryRunActor")
  deploymentRuns       DeploymentRun[] @relation("DeploymentRunActor")
  serverExecutionLeases ServerExecutionLease[] @relation("ServerExecutionLeaseActor")
  serverExecutionJobs ServerExecutionJob[] @relation("ServerExecutionJobActor")
  createdServerCommandPolicyTemplates ServerCommandPolicyTemplate[] @relation("ServerCommandPolicyTemplateCreator")
  createdControlAccessPolicies ControlAccessPolicy[] @relation("ControlAccessPolicyCreator")
  principalControlAccessPolicies ControlAccessPolicy[] @relation("ControlAccessPolicyPrincipalUser")
  applicationServiceOperationRuns ApplicationServiceOperationRun[] @relation("ApplicationServiceOperationRunActor")
  auditEvents          AuditEvent[] @relation("AuditEventActor")
  requestedOperationApprovals OperationApproval[] @relation("OperationApprovalRequester")
  reviewedOperationApprovals  OperationApproval[] @relation("OperationApprovalReviewer")
  createdBackupPlans  BackupPlan[] @relation("BackupPlanCreator")
  backupRuns          BackupRun[] @relation("BackupRunActor")
  createdAlertRules   AlertRule[] @relation("AlertRuleCreator")
  createdAlertSilences AlertSilence[] @relation("AlertSilenceCreator")
  createdAlertNotificationChannels AlertNotificationChannel[] @relation("AlertNotificationChannelCreator")
  alertEvents         AlertEvent[] @relation("AlertEventActor")
  createdLogStreams   LogStream[] @relation("LogStreamCreator")
  logEntries          LogEntry[] @relation("LogEntryActor")
  logCollectionRuns   LogCollectionRun[] @relation("LogCollectionRunActor")
  logRetentionRuns    LogRetentionRun[] @relation("LogRetentionRunActor")
  createdResourceTypes ResourceType[] @relation("ResourceTypeCreator")
  resourceRequests     ResourceRequest[] @relation("ResourceRequester")
  reviewedResourceRequests ResourceRequest[] @relation("ResourceReviewer")
  resourceAuditLogs    ResourceAuditLog[] @relation("ResourceAuditActor")
  resourceProvisioningRuns ResourceProvisioningRun[] @relation("ResourceProvisioningRunActor")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 团队
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?

  // 团队成员
  members     TeamMember[]

  // 团队资源
  servers       Server[]
  proxyConfigs  ProxyConfig[]
  sites         Site[]
  siteSyncRuns SiteSyncRun[]
  cdnConfigs    CDNConfig[]
  credentials   TeamCredential[]
  projects      Project[]
  projectEnvironments ProjectEnvironment[]
  projectEnvironmentServers ProjectEnvironmentServer[]
  applications  Application[]
  applicationServices ApplicationService[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  auditEvents  AuditEvent[]
  operationApprovals OperationApproval[]
  backupPlans BackupPlan[]
  backupRuns  BackupRun[]
  alertRules  AlertRule[]
  alertSilences AlertSilence[]
  alertEvents AlertEvent[]
  alertNotificationChannels AlertNotificationChannel[]
  alertNotificationDeliveries AlertNotificationDelivery[]
  logStreams  LogStream[]
  logEntries  LogEntry[]
  logCollectionRuns LogCollectionRun[]
  logRetentionRuns LogRetentionRun[]
  resources     Resource[]
  presets       Preset[]
  secretKeys    SecretKey[]
  managedResources ManagedResource[]
  resourceSyncRuns ResourceSyncRun[]
  resourceActionRuns ResourceActionRun[]
  resourceMetricSnapshots ResourceMetricSnapshot[]
  resourceConnectionRuns ResourceConnectionRun[]
  resourceQueryRuns ResourceQueryRun[]
  deploymentRuns DeploymentRun[]
  serverExecutionLeases ServerExecutionLease[]
  serverExecutionJobs ServerExecutionJob[]
  serverCommandPolicyTemplates ServerCommandPolicyTemplate[]
  controlAccessPolicies ControlAccessPolicy[]
  projectWebhooks ProjectWebhook[]
  webhookDeliveries WebhookDelivery[]
  resourceRequests ResourceRequest[]
  resourceInstances ResourceInstance[]
  resourceAuditLogs ResourceAuditLog[]
  resourceProvisioningRuns ResourceProvisioningRun[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 团队成员
model TeamMember {
  id      String @id @default(cuid())
  teamId  String
  userId  String
  role    String @default("member") // owner | admin | member

  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

// ==================== OAuth ====================

// OAuth 账号关联
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Git 连接
model GitConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // github | gitlab | gitee
  accessToken  String   @db.Text // 加密存储
  refreshToken String?  @db.Text
  username     String

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
}

// ==================== 服务器管理 ====================

// 服务器
model Server {
  id          String   @id @default(cuid())
  teamId      String
  createdById String
  name        String
  host        String
  port        Int      @default(22)
  username    String
  authType    String   // password | key
  credentials String   @db.Text // 加密存储的密码或私钥
  tags        Json?    // string[]
  status      String   @default("unknown") // online | offline | unknown
  services    Json?    // 检测到的服务 { nginx: true, docker: true, ... }

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  proxyConfigs ProxyConfig[]
  sites       Site[]
  siteSyncRuns SiteSyncRun[]
  environmentBindings ProjectEnvironmentServer[]
  applicationServices ApplicationService[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  auditEvents  AuditEvent[]
  operationApprovals OperationApproval[]
  backupPlans BackupPlan[]
  backupRuns  BackupRun[]
  alertRules  AlertRule[]
  alertEvents AlertEvent[]
  logStreams  LogStream[]
  logEntries  LogEntry[]
  logCollectionRuns LogCollectionRun[]
  managedResources ManagedResource[]
  resourceSyncRuns ResourceSyncRun[]
  deploymentRuns DeploymentRun[]
  serverExecutionLeases ServerExecutionLease[]
  serverExecutionJobs ServerExecutionJob[]
  resourceConnectionRuns ResourceConnectionRun[]
  resourceQueryRuns ResourceQueryRun[]
  resourceMetricSnapshots ResourceMetricSnapshot[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
}

// Server executor live 执行互斥 lease
model ServerExecutionLease {
  id           String   @id @default(cuid())
  teamId       String
  actorId      String?
  serverId     String?
  activeKey    String?  @unique
  operationKey String
  adapterKey   String
  transport    String
  dryRun       Boolean  @default(false)
  status       String   @default("running") // running | completed | failed | blocked | expired
  metadata     Json?
  acquiredAt   DateTime @default(now())
  releasedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor        User?    @relation("ServerExecutionLeaseActor", fields: [actorId], references: [id], onDelete: SetNull)
  server       Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([actorId])
  @@index([serverId])
  @@index([operationKey])
  @@index([adapterKey])
  @@index([transport])
  @@index([dryRun])
  @@index([status])
  @@index([acquiredAt])
  @@index([releasedAt])
  @@index([expiresAt])
}

// Server executor 执行任务历史与重试入口
model ServerExecutionJob {
  id            String   @id @default(cuid())
  teamId        String
  actorId       String?
  serverId      String?
  retryOfId     String?
  operationKey  String
  adapterKey    String
  transport     String
  dryRun        Boolean  @default(true)
  status        String   @default("running") // queued | running | completed | failed | blocked | cancelled
  queueMode     String   @default("inline") // inline | queued
  priority      Int      @default(0)
  attempt       Int      @default(1)
  maxAttempts   Int      @default(1)
  inputSnapshot Json
  commandPlan   Json?
  logs          Json?
  result        Json?
  error         String?  @db.Text
  metadata      Json?
  queuedAt      DateTime @default(now())
  availableAt   DateTime @default(now())
  lockedAt      DateTime?
  lockOwner     String?
  lockExpiresAt DateTime?
  lastHeartbeatAt DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  cancelRequestedAt DateTime?
  cancelledAt   DateTime?
  recoveredAt   DateTime?
  recoveryReason String? @db.Text
  recoveryCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor         User?    @relation("ServerExecutionJobActor", fields: [actorId], references: [id], onDelete: SetNull)
  server        Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  retryOf       ServerExecutionJob? @relation("ServerExecutionJobRetry", fields: [retryOfId], references: [id], onDelete: SetNull)
  retryAttempts ServerExecutionJob[] @relation("ServerExecutionJobRetry")
  deploymentRuns DeploymentRun[]
  siteSyncRuns SiteSyncRun[]
  resourceActionRuns ResourceActionRun[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  backupRuns BackupRun[]
  logCollectionRuns LogCollectionRun[]

  @@index([teamId])
  @@index([actorId])
  @@index([serverId])
  @@index([retryOfId])
  @@index([operationKey])
  @@index([adapterKey])
  @@index([transport])
  @@index([dryRun])
  @@index([status])
  @@index([queueMode])
  @@index([queuedAt])
  @@index([availableAt])
  @@index([lockedAt])
  @@index([lockOwner])
  @@index([lockExpiresAt])
  @@index([cancelRequestedAt])
  @@index([recoveredAt])
  @@index([startedAt])
  @@index([finishedAt])
}

// Server executor 命令策略模板
model ServerCommandPolicyTemplate {
  id              String   @id @default(cuid())
  teamId          String
  createdById     String?
  projectId       String?
  environmentId   String?
  name            String
  description     String?  @db.Text
  enabled         Boolean  @default(true)
  priority        Int      @default(0)
  adapterKeys     Json?
  operationKeys   Json?
  allowedPatterns Json?
  blockedPatterns Json?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("ServerCommandPolicyTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([createdById])
  @@index([projectId])
  @@index([environmentId])
  @@index([enabled])
  @@index([priority])
}

// ==================== 代理配置 ====================

// 代理配置（类似 nginx-proxy-manager）
model ProxyConfig {
  id           String   @id @default(cuid())
  teamId       String
  createdById  String
  serverId     String?
  projectId    String?
  name         String
  domain       String
  upstreams    Json     // [{ host: string, port: number, weight?: number }]
  ssl          Json     // { enabled: boolean, type: 'letsencrypt' | 'custom' | 'none', certificate?: string, privateKey?: string }
  websocket    Boolean  @default(false)
  customConfig String?  @db.Text // 自定义 Nginx 配置片段
  status       String   @default("pending") // pending | active | error
  lastSyncAt   DateTime?
  syncError    String?  @db.Text

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  server      Server?  @relation(fields: [serverId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  sites       Site[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([domain])
  @@index([projectId])
}

// ==================== 站点管控 ====================

// 站点（面向域名、运行时、TLS、访问策略的上层管控对象）
model Site {
  id            String   @id @default(cuid())
  teamId        String
  createdById   String
  projectId     String?
  serverId      String?
  environmentId String?
  proxyConfigId String?
  name          String
  primaryDomain String
  aliases       Json?
  runtimeType   String   @default("reverse_proxy") // reverse_proxy | static | docker | runtime
  runtimeConfig Json?
  tls           Json?
  accessPolicy  Json?
  status        String   @default("draft") // draft | pending | active | error
  lastSyncAt    DateTime?
  syncError     String?  @db.Text

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy     User     @relation("SiteCreator", fields: [createdById], references: [id])
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment   ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  server        Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  proxyConfig   ProxyConfig? @relation(fields: [proxyConfigId], references: [id], onDelete: SetNull)
  applicationServices ApplicationService[]
  syncRuns      SiteSyncRun[]
  auditEvents   AuditEvent[]
  operationApprovals OperationApproval[]
  alertRules    AlertRule[]
  alertEvents   AlertEvent[]
  logStreams    LogStream[]
  logEntries    LogEntry[]
  logCollectionRuns LogCollectionRun[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teamId])
  @@index([createdById])
  @@index([projectId])
  @@index([environmentId])
  @@index([serverId])
  @@index([proxyConfigId])
  @@index([primaryDomain])
  @@index([runtimeType])
  @@index([status])
}

// 站点同步/回滚运行记录
model SiteSyncRun {
  id               String   @id @default(cuid())
  teamId           String
  actorId          String?
  siteId           String
  projectId        String?
  environmentId    String?
  serverId         String?
  sourceRunId      String?
  operationApprovalId String?
  serverExecutionJobId String?
  mode             String   @default("sync") // sync | rollback
  trigger          String   @default("manual") // manual | manual_rollback | webhook | api
  executorKey      String   @default("server-executor")
  adapterKey       String   @default("nginx-site-plan")
  dryRun           Boolean  @default(true)
  status           String   @default("running") // queued | running | completed | failed | blocked | cancelled
  targetConfigPath String?
  nginxConfig      String   @db.Text
  commandPlan      Json?
  configDiff       Json?
  executionPlan    Json?
  logs             Json?
  result           Json?
  warnings         Json?
  error            String?  @db.Text
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  createdAt        DateTime @default(now())

  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor            User?    @relation("SiteSyncRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment      ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  server           Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  sourceRun        SiteSyncRun? @relation("SiteSyncRollbackSource", fields: [sourceRunId], references: [id], onDelete: SetNull)
  rollbackRuns     SiteSyncRun[] @relation("SiteSyncRollbackSource")
  operationApproval OperationApproval? @relation(fields: [operationApprovalId], references: [id], onDelete: SetNull)
  serverExecutionJob ServerExecutionJob? @relation(fields: [serverExecutionJobId], references: [id], onDelete: SetNull)
  auditEvents      AuditEvent[]

  @@index([teamId])
  @@index([actorId])
  @@index([siteId])
  @@index([projectId])
  @@index([environmentId])
  @@index([serverId])
  @@index([sourceRunId])
  @@index([operationApprovalId])
  @@index([serverExecutionJobId])
  @@index([mode])
  @@index([trigger])
  @@index([executorKey])
  @@index([adapterKey])
  @@index([dryRun])
  @@index([status])
  @@index([startedAt])
}

// ==================== CDN 配置 ====================

// 团队凭证（CDN、云服务等）
model TeamCredential {
  id        String   @id @default(cuid())
  teamId    String
  type      String   // cdn_qiniu | cdn_aliyun | cdn_cloudflare | cloud_aws | etc.
  name      String
  config    String   @db.Text // 加密的凭证配置 JSON

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  cdnConfigs CDNConfig[]
  managedResources ManagedResource[]
  resourceSyncRuns ResourceSyncRun[]
  resourceActionRuns ResourceActionRun[]
  resourceConnectionRuns ResourceConnectionRun[]
  resourceQueryRuns ResourceQueryRun[]
  resourceProvisioningRuns ResourceProvisioningRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, type])
}

// CDN 配置
model CDNConfig {
  id           String   @id @default(cuid())
  teamId       String
  createdById  String
  projectId    String?
  environmentId String?
  credentialId String
  name         String
  domain       String
  origin       String   // 源站地址
  provider     String   // qiniu | aliyun | cloudflare
  cacheRules   Json?    // [{ path: string, ttl: number }]
  status       String   @default("pending") // pending | active | error
  providerData Json?    // CDN 提供商返回的数据
  syncError    String?  @db.Text

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
  environment  ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  credential   TeamCredential @relation(fields: [credentialId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teamId])
  @@index([domain])
  @@index([projectId])
  @@index([environmentId])
}

// ==================== 项目与资源 ====================

// 资源凭证（团队级别）
model Resource {
  id        String   @id @default(cuid())
  teamId    String
  createdById String
  type      String   // mysql | redis | qiniu-kodo | etc.
  name      String
  config    String   @db.Text // 加密的 JSON 配置

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, type])
}

// 配置预设（团队级别）
model Preset {
  id        String   @id @default(cuid())
  teamId    String
  createdById String
  name      String
  config    Json     // ProjectConfig

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
}

// 生成的项目记录（团队级别）
model Project {
  id           String   @id @default(cuid())
  teamId       String
  createdById  String
  name         String
  description  String?
  config       Json     // ProjectConfig snapshot
  gitRepo      String?  // 推送的仓库地址
  downloadUrl  String?  // ZIP 下载链接（临时）

  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id])
  allocations  ResourceAllocation[]
  environments ProjectEnvironment[]
  proxyConfigs ProxyConfig[]
  sites        Site[]
  siteSyncRuns SiteSyncRun[]
  applications Application[]
  applicationServices ApplicationService[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  auditEvents  AuditEvent[]
  operationApprovals OperationApproval[]
  backupPlans BackupPlan[]
  backupRuns  BackupRun[]
  alertRules  AlertRule[]
  alertSilences AlertSilence[]
  alertEvents AlertEvent[]
  logStreams  LogStream[]
  logEntries  LogEntry[]
  logCollectionRuns LogCollectionRun[]
  resourceConnectionRuns ResourceConnectionRun[]
  resourceQueryRuns ResourceQueryRun[]
  resourceMetricSnapshots ResourceMetricSnapshot[]
  cdnConfigs   CDNConfig[]
  secretKeys   SecretKey[]
  managedResources ManagedResource[]
  resourceRequests ResourceRequest[]
  resourceInstances ResourceInstance[]
  resourceProvisioningRuns ResourceProvisioningRun[]
  deploymentRuns DeploymentRun[]
  projectWebhooks ProjectWebhook[]
  webhookDeliveries WebhookDelivery[]
  environmentServers ProjectEnvironmentServer[]
  serverCommandPolicyTemplates ServerCommandPolicyTemplate[]
  controlAccessPolicies ControlAccessPolicy[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teamId])
  @@index([createdById])
}

// 项目环境
model ProjectEnvironment {
  id          String   @id @default(cuid())
  teamId      String
  projectId   String
  key         String
  name        String
  description String?  @db.Text
  status      String   @default("active") // active | archived
  sortOrder   Int      @default(0)
  config      Json?

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serverBindings ProjectEnvironmentServer[]
  applicationServices ApplicationService[]
  applicationServiceOperationRuns ApplicationServiceOperationRun[]
  sites       Site[]
  siteSyncRuns SiteSyncRun[]
  deploymentRuns DeploymentRun[]
  managedResources ManagedResource[]
  resourceRequests ResourceRequest[]
  resourceInstances ResourceInstance[]
  resourceProvisioningRuns ResourceProvisioningRun[]
  cdnConfigs CDNConfig[]
  secretKeys SecretKey[]
  auditEvents AuditEvent[]
  operationApprovals OperationApproval[]
  backupPlans BackupPlan[]
  backupRuns  BackupRun[]
  alertRules AlertRule[]
  alertSilences AlertSilence[]
  alertEvents AlertEvent[]
  logStreams LogStream[]
  logEntries LogEntry[]
  logCollectionRuns LogCollectionRun[]
  resourceConnectionRuns ResourceConnectionRun[]
  resourceQueryRuns ResourceQueryRun[]
  resourceMetricSnapshots ResourceMetricSnapshot[]
  serverCommandPolicyTemplates ServerCommandPolicyTemplate[]
  controlAccessPolicies ControlAccessPolicy[]
  projectWebhooks ProjectWebhook[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, key])
  @@index([teamId])
  @@index([projectId])
  @@index([key])
  @@index([status])
}

// 控制面访问策略：项目/环境/动作级 RBAC
model ControlAccessPolicy {
  id              String   @id @default(cuid())
  teamId          String
  createdById     String?
  principalUserId String?
  projectId       String?
  environmentId   String?
  name            String
  description     String?  @db.Text
  enabled         Boolean  @default(true)
  effect          String   @default("allow") // allow | deny
  principalType   String   @default("team_role") // team_role | user | any
  principalRole   String?  // owner | admin | member
  categories      Json?
  actions         Json?
  riskLevels      Json?
  priority        Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("ControlAccessPolicyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  principalUser   User?    @relation("ControlAccessPolicyPrincipalUser", fields: [principalUserId], references: [id], onDelete: SetNull)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([createdById])
  @@index([principalUserId])
  @@index([projectId])
  @@index([environmentId])
  @@index([enabled])
  @@index([effect])
  @@index([principalType])
  @@index([principalRole])
  @@index([priority])
}

// 项目环境与服务器的绑定关系
model ProjectEnvironmentServer {
  id            String   @id @default(cuid())
  teamId        String
  projectId     String
  environmentId String
  serverId      String
  role          String?
  status        String   @default("active") // active | archived
  metadata      Json?

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment   ProjectEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([environmentId, serverId])
  @@index([teamId])
  @@index([projectId])
  @@index([environmentId])
  @@index([serverId])
  @@index([role])
  @@index([status])
}

// 项目应用
model Application {
  id            String   @id @default(cuid())
  teamId        String
  projectId     String
  createdById   String?
  name          String
  description   String?  @db.Text
  repositoryUrl String?
  repoPath      String?
  defaultBranch String?
  status        String   @default("active") // active | archived
  config        Json?

  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation("ApplicationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  services      ApplicationService[]
  deploymentRuns DeploymentRun[]
  operationRuns ApplicationServiceOperationRun[]
  auditEvents   AuditEvent[]
  operationApprovals OperationApproval[]
  alertRules    AlertRule[]
  alertEvents   AlertEvent[]
  logStreams    LogStream[]
  logEntries    LogEntry[]
  logCollectionRuns LogCollectionRun[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, name])
  @@index([teamId])
  @@index([projectId])
  @@index([createdById])
  @@index([status])
}

// 应用在项目环境中的服务实例
model ApplicationService {
  id                String   @id @default(cuid())
  teamId            String
  projectId         String
  applicationId     String
  environmentId     String
  serverId          String?
  siteId            String?
  managedResourceId String?
  name              String
  kind              String   @default("docker-compose") // docker-compose | container | static | external
  runtime           String?
  image             String?
  ports             Json?
  env               Json?
  secretKeyIds      Json?
  deployConfig      Json?
  status            String   @default("active") // active | inactive | archived
  metadata          Json?

  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  environment       ProjectEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  server            Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  site              Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managedResource   ManagedResource? @relation(fields: [managedResourceId], references: [id], onDelete: SetNull)
  deploymentRuns    DeploymentRun[]
  operationRuns     ApplicationServiceOperationRun[]
  auditEvents       AuditEvent[]
  operationApprovals OperationApproval[]
  alertRules        AlertRule[]
  alertEvents       AlertEvent[]
  logStreams        LogStream[]
  logEntries        LogEntry[]
  logCollectionRuns LogCollectionRun[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([applicationId, environmentId, name])
  @@index([teamId])
  @@index([projectId])
  @@index([applicationId])
  @@index([environmentId])
  @@index([serverId])
  @@index([siteId])
  @@index([managedResourceId])
  @@index([kind])
  @@index([status])
}

// 应用服务运行态操作记录
model ApplicationServiceOperationRun {
  id                   String   @id @default(cuid())
  teamId               String
  projectId            String
  applicationId        String
  applicationServiceId String
  environmentId        String?
  serverId             String?
  actorId              String?
  operationApprovalId  String?
  serverExecutionJobId String?
  action               String   // status | logs | restart | rollback
  executorKey          String   @default("server-executor")
  adapterKey           String   @default("script-plan")
  dryRun               Boolean  @default(true)
  risk                 String   @default("low") // low | medium | high
  status               String   @default("running") // running | completed | failed | blocked
  params               Json?
  commandPlan          Json?
  logs                 Json?
  result               Json?
  error                String?  @db.Text
  startedAt            DateTime @default(now())
  finishedAt           DateTime?
  createdAt            DateTime @default(now())

  team                 Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationService   ApplicationService @relation(fields: [applicationServiceId], references: [id], onDelete: Cascade)
  environment          ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  server               Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  actor                User?    @relation("ApplicationServiceOperationRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  operationApproval    OperationApproval? @relation(fields: [operationApprovalId], references: [id], onDelete: SetNull)
  serverExecutionJob   ServerExecutionJob? @relation(fields: [serverExecutionJobId], references: [id], onDelete: SetNull)
  auditEvents          AuditEvent[]

  @@index([teamId])
  @@index([projectId])
  @@index([applicationId])
  @@index([applicationServiceId])
  @@index([environmentId])
  @@index([serverId])
  @@index([actorId])
  @@index([operationApprovalId])
  @@index([serverExecutionJobId])
  @@index([action])
  @@index([executorKey])
  @@index([adapterKey])
  @@index([status])
  @@index([startedAt])
}

// 项目部署运行记录
model DeploymentRun {
  id               String   @id @default(cuid())
  teamId           String
  projectId        String
  actorId          String?
  serverId         String?
  environmentId    String?
  applicationId     String?
  applicationServiceId String?
  serverExecutionJobId String?
  operationApprovalId String?
  sourceRunId      String?
  environment      String?
  mode             String   @default("deploy") // deploy | rollback
  source           String   @default("manual") // manual | webhook | api
  trigger          String   @default("manual") // manual | git_push | api
  targetType       String   // docker-compose | server | kubernetes | external-ci
  executorKey      String   @default("server-executor")
  adapterKey       String   @default("script-plan")
  dryRun           Boolean  @default(true)
  status           String   @default("running") // running | completed | failed | blocked
  gitRepo          String?
  branch           String?
  commitSha        String?
  workingDirectory String?
  buildCommand     String?  @db.Text
  deployCommand    String?  @db.Text
  healthCheckUrl   String?
  params           Json?
  commandPlan      Json?
  logs             Json?
  result           Json?
  error            String?  @db.Text
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  createdAt        DateTime @default(now())
  webhookDeliveries WebhookDelivery[]

  team             Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectEnvironment ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  application      Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  applicationService ApplicationService? @relation(fields: [applicationServiceId], references: [id], onDelete: SetNull)
  actor            User?    @relation("DeploymentRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  server           Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverExecutionJob ServerExecutionJob? @relation(fields: [serverExecutionJobId], references: [id], onDelete: SetNull)
  operationApproval OperationApproval? @relation(fields: [operationApprovalId], references: [id], onDelete: SetNull)
  sourceRun        DeploymentRun? @relation("DeploymentRollbackSource", fields: [sourceRunId], references: [id], onDelete: SetNull)
  rollbackRuns     DeploymentRun[] @relation("DeploymentRollbackSource")
  auditEvents      AuditEvent[]
  logStreams       LogStream[]
  logEntries       LogEntry[]
  logCollectionRuns LogCollectionRun[]

  @@index([teamId])
  @@index([projectId])
  @@index([actorId])
  @@index([serverId])
  @@index([environmentId])
  @@index([applicationId])
  @@index([applicationServiceId])
  @@index([serverExecutionJobId])
  @@index([operationApprovalId])
  @@index([sourceRunId])
  @@index([environment])
  @@index([mode])
  @@index([source])
  @@index([targetType])
  @@index([status])
  @@index([startedAt])
}

// 项目 Git Webhook 配置
model ProjectWebhook {
  id             String   @id @default(cuid())
  teamId         String
  projectId      String
  environmentId  String?
  createdById    String?
  name           String
  provider       String   @default("github") // github | gitlab | gitee | generic
  urlToken       String   @unique
  secret         String   @db.Text
  enabled        Boolean  @default(true)
  eventTypes     Json?
  branchPattern  String?
  tagPattern     String?
  deploymentMode String   @default("dry_run") // dry_run | queue | live_request
  maxAttempts    Int      @default(1)
  lastDeliveryAt DateTime?

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment    ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  createdBy      User?    @relation("ProjectWebhookCreator", fields: [createdById], references: [id], onDelete: SetNull)
  deliveries     WebhookDelivery[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([teamId])
  @@index([projectId])
  @@index([environmentId])
  @@index([createdById])
  @@index([provider])
  @@index([enabled])
  @@index([deploymentMode])
}

// Webhook 投递记录
model WebhookDelivery {
  id               String   @id @default(cuid())
  webhookId        String
  teamId           String
  projectId        String
  deploymentRunId  String?
  eventType        String
  providerEventId  String?
  idempotencyKey   String?
  sourceIp         String?
  signatureStatus  String   @default("unchecked") // valid | invalid | missing | unchecked
  payloadHash      String
  payload          Json?
  status           String   @default("received") // received | accepted | ignored | failed
  message          String?  @db.Text
  receivedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  webhook          ProjectWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  team             Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deploymentRun    DeploymentRun? @relation(fields: [deploymentRunId], references: [id], onDelete: SetNull)

  @@index([webhookId])
  @@index([teamId])
  @@index([projectId])
  @@index([deploymentRunId])
  @@index([eventType])
  @@index([providerEventId])
  @@index([idempotencyKey])
  @@index([signatureStatus])
  @@index([status])
  @@index([receivedAt])
  @@unique([webhookId, idempotencyKey])
}

// 密钥中心（团队级别）
model SecretKey {
  id          String   @id @default(cuid())
  teamId      String
  createdById String
  projectId   String?  // 关联的项目ID（可选）
  environmentId String?
  name        String   // 密钥名称
  type        String   // jwt_secret | encryption_key | api_key | oauth_secret | database_password | custom
  value       String   @db.Text // 加密存储的密钥值
  description String?  // 描述

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  environment ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([projectId])
  @@index([environmentId])
}

// ==================== 资源池（系统级别） ====================

// 资源池
model ResourcePool {
  id          String   @id @default(cuid())
  type        String   // mysql | redis | nginx | cdn
  name        String
  endpoint    String   // 连接地址
  adminConfig String   @db.Text // 加密的管理员凭证
  capacity    Int      // 最大容量
  allocated   Int      @default(0)  // 已分配数量
  status      String   @default("active")  // active | maintenance | full

  allocations ResourceAllocation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 资源分配记录
model ResourceAllocation {
  id           String   @id @default(cuid())
  poolId       String
  projectId    String
  teamId       String
  userId       String   // 创建者

  resourceName String   // 如数据库名、Redis DB 号
  credentials  String   @db.Text // 加密的凭证
  config       Json     // 其他配置

  pool         ResourcePool @relation(fields: [poolId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  status       String   @default("active")  // active | released
  createdAt    DateTime @default(now())
  releasedAt   DateTime?

  @@index([projectId])
  @@index([teamId])
  @@index([poolId])
  @@index([userId])
}

// ==================== 动态资源申请 ====================

// 动态资源类型（系统级别）
model ResourceType {
  id                 String   @id @default(cuid())
  key                String   @unique
  name               String
  description        String?  @db.Text
  category           String?
  icon               String?
  enabled            Boolean  @default(true)
  requestSchema      Json?    // 申请表单 schema
  deliverySchema     Json?    // 交付结果 schema
  envTemplate        String?  @db.Text
  approvalMode       String   @default("manual") // manual | auto | none
  provisioningMode   String   @default("manual") // manual | pool | webhook | api | script | credential_only
  provisioningConfig Json?
  createdById        String?

  createdBy          User?    @relation("ResourceTypeCreator", fields: [createdById], references: [id])
  requests           ResourceRequest[]
  instances          ResourceInstance[]
  auditLogs          ResourceAuditLog[]
  provisioningRuns   ResourceProvisioningRun[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category])
  @@index([enabled])
  @@index([createdById])
}

// 统一资源申请单（团队级别）
model ResourceRequest {
  id             String   @id @default(cuid())
  teamId         String
  projectId      String?
  environmentId  String?
  resourceTypeId String
  requesterId    String
  reviewerId     String?
  title          String
  environment    String?
  purpose        String?  @db.Text
  spec           Json
  status         String   @default("pending") // pending | approved | rejected | completed | canceled
  approvalComment String? @db.Text
  result         Json?
  requestedAt    DateTime @default(now())
  reviewedAt     DateTime?
  completedAt    DateTime?
  canceledAt     DateTime?

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project? @relation(fields: [projectId], references: [id])
  projectEnvironment ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])
  requester      User     @relation("ResourceRequester", fields: [requesterId], references: [id])
  reviewer       User?    @relation("ResourceReviewer", fields: [reviewerId], references: [id])
  instance       ResourceInstance?
  auditLogs      ResourceAuditLog[]
  provisioningRuns ResourceProvisioningRun[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([teamId])
  @@index([projectId])
  @@index([environmentId])
  @@index([resourceTypeId])
  @@index([requesterId])
  @@index([reviewerId])
  @@index([status])
}

// 资源实例（申请交付后的实际资源）
model ResourceInstance {
  id             String   @id @default(cuid())
  teamId         String
  projectId      String?
  environmentId  String?
  requestId      String?  @unique
  resourceTypeId String
  name           String
  status         String   @default("active") // active | released | expired | revoked
  config         Json?
  credentials    String?  @db.Text // 加密存储的敏感交付结果
  delivery       Json?
  expiresAt      DateTime?
  releasedAt     DateTime?

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project? @relation(fields: [projectId], references: [id])
  projectEnvironment ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  request        ResourceRequest? @relation(fields: [requestId], references: [id])
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])
  managedResources ManagedResource[]
  auditLogs      ResourceAuditLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([teamId])
  @@index([projectId])
  @@index([environmentId])
  @@index([resourceTypeId])
  @@index([status])
}

// 资源申请审计日志
model ResourceAuditLog {
  id             String   @id @default(cuid())
  teamId         String
  resourceTypeId String?
  requestId      String?
  instanceId     String?
  provisioningRunId String?
  actorId        String?
  action         String
  message        String?  @db.Text
  metadata       Json?

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  resourceType   ResourceType? @relation(fields: [resourceTypeId], references: [id])
  request        ResourceRequest? @relation(fields: [requestId], references: [id])
  instance       ResourceInstance? @relation(fields: [instanceId], references: [id])
  provisioningRun ResourceProvisioningRun? @relation(fields: [provisioningRunId], references: [id], onDelete: SetNull)
  actor          User?    @relation("ResourceAuditActor", fields: [actorId], references: [id])

  createdAt      DateTime @default(now())

  @@index([teamId])
  @@index([resourceTypeId])
  @@index([requestId])
  @@index([instanceId])
  @@index([provisioningRunId])
  @@index([actorId])
  @@index([action])
}

// 资源申请外部交付运行记录
model ResourceProvisioningRun {
  id             String   @id @default(cuid())
  teamId         String
  actorId        String?
  replayOfRunId  String?
  requestId      String
  resourceTypeId String
  projectId      String?
  environmentId  String?
  credentialId   String?
  mode           String   // api | webhook
  trigger        String   // approval | manual_retry | auto_retry
  boundary       String   @default("http_adapter")
  executorKey    String   @default("resource-request")
  adapterKey     String
  authAdapterKey String?
  idempotencyKey String
  providerRunId  String?
  status         String   @default("running") // queued | running | planned | blocked | completed | failed
  queueMode      String   @default("inline") // inline | queued
  attempt        Int      @default(0)
  maxAttempts    Int      @default(1)
  retryable      Boolean  @default(false)
  autoRetry      Boolean  @default(false)
  params         Json?
  result         Json?
  error          String?  @db.Text
  startedAt      DateTime @default(now())
  queuedAt       DateTime?
  availableAt    DateTime?
  lockedAt       DateTime?
  lockOwner      String?
  finishedAt     DateTime?
  recoveredAt    DateTime?
  recoveryReason String?  @db.Text
  recoveryCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor          User?    @relation("ResourceProvisioningRunActor", fields: [actorId], references: [id], onDelete: SetNull)
  replayOf       ResourceProvisioningRun? @relation("ResourceProvisioningRunReplay", fields: [replayOfRunId], references: [id], onDelete: SetNull)
  replayAttempts ResourceProvisioningRun[] @relation("ResourceProvisioningRunReplay")
  request        ResourceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  resourceType   ResourceType @relation(fields: [resourceTypeId], references: [id])
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment    ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  credential     TeamCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  auditLogs      ResourceAuditLog[]

  @@index([teamId])
  @@index([actorId])
  @@index([replayOfRunId])
  @@index([requestId])
  @@index([resourceTypeId])
  @@index([projectId])
  @@index([environmentId])
  @@index([credentialId])
  @@index([mode])
  @@index([trigger])
  @@index([boundary])
  @@index([executorKey])
  @@index([adapterKey])
  @@index([authAdapterKey])
  @@index([idempotencyKey])
  @@index([providerRunId])
  @@index([status])
  @@index([queueMode])
  @@index([startedAt])
  @@index([availableAt])
  @@index([lockedAt])
  @@index([recoveredAt])
  @@index([teamId, status, queueMode, availableAt])
}

// ==================== 基础设施资源管控 ====================

// 已纳管或已发现的服务器/云资源清单
model ManagedResource {
  id                 String   @id @default(cuid())
  teamId             String
  createdById        String?
  serverId           String?
  projectId          String?
  environmentId      String?
  resourceInstanceId String?
  credentialId       String?
  sourceType         String   // server | cloud | manual
  provider           String   // docker | aliyun-rds | aliyun-sls | tencent-cos
  kind               String   // docker_container | mysql | redis | database | log_service | object_storage
  name               String
  externalId         String
  status             String   @default("unknown") // running | stopped | active | inactive | unknown | error
  endpoint           String?
  metadata           Json?
  config             Json?
  lastSyncAt         DateTime?
  syncError          String?  @db.Text

  team               Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy          User?    @relation("ManagedResourceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  server             Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  environment        ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  resourceInstance   ResourceInstance? @relation(fields: [resourceInstanceId], references: [id], onDelete: SetNull)
  credential         TeamCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  applicationServices ApplicationService[]
  actionRuns         ResourceActionRun[]
  metricSnapshots    ResourceMetricSnapshot[]
  connectionRuns     ResourceConnectionRun[]
  queryRuns          ResourceQueryRun[]
  auditEvents        AuditEvent[]
  operationApprovals OperationApproval[]
  backupPlans        BackupPlan[]
  backupRuns         BackupRun[]
  alertRules         AlertRule[]
  alertEvents        AlertEvent[]
  logStreams         LogStream[]
  logEntries         LogEntry[]
  logCollectionRuns  LogCollectionRun[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([teamId, sourceType, provider, externalId])
  @@index([teamId])
  @@index([createdById])
  @@index([serverId])
  @@index([projectId])
  @@index([environmentId])
  @@index([resourceInstanceId])
  @@index([credentialId])
  @@index([sourceType])
  @@index([provider])
  @@index([kind])
  @@index([status])
}

// 资源同步运行记录
model ResourceSyncRun {
  id           String   @id @default(cuid())
  teamId       String
  actorId      String?
  serverId     String?
  credentialId String?
  sourceType   String   // server | cloud
  provider     String   // docker | aliyun-rds | aliyun-sls | tencent-cos | all
  scope        String?
