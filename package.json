{
  "name": "svton",
  "version": "1.0.0",
  "private": true,
  "description": "Svton Framework - Full-stack application framework with CLI, packages, and templates",
  "keywords": [
    "svton",
    "framework",
    "full-stack",
    "cli",
    "nestjs",
    "nextjs",
    "taro",
    "typescript",
    "monorepo"
  ],
  "author": "SVTON Team",
  "license": "MIT",
  "homepage": "https://github.com/svton/svton#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/svton/svton.git"
  },
  "bugs": {
    "url": "https://github.com/svton/svton/issues"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "skills:build": "node ./skills/scripts/build-all.mjs",
    "skills:validate": "node ./skills/scripts/validate-all.mjs",
    "skills:rebuild": "pnpm skills:build && pnpm skills:validate",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "pub:version": "changeset version",
    "prepub": "pnpm build",
    "pub": "changeset publish",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "init:dev": "turbo run dev --filter=@svton/devpilot-web --filter=@svton/devpilot-api",
    "init:web": "pnpm --filter @svton/devpilot-web dev",
    "init:api": "pnpm --filter @svton/devpilot-api dev",
    "init:build": "turbo run build --filter=@svton/devpilot-web --filter=@svton/devpilot-api"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@svton/cli": "workspace:*",
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.12.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "svton": {
    "schema": 1
  }
}
